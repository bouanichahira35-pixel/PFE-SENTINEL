# Docker local overrides for docker-compose.yml.
# Copy to `.env` at the repository root only if you want to override defaults.

# Required secrets in production. Defaults in docker-compose.yml are dev-only.
DOCKER_JWT_SECRET=sentinel_docker_dev_jwt_secret_32_chars
DOCKER_PII_HASH_SECRET=sentinel_docker_dev_pii_secret_32_chars
DOCKER_INTERNAL_BOND_QR_SECRET=sentinel_docker_dev_qr_secret_32_chars
DOCKER_SUPPLIER_PORTAL_JWT_SECRET=sentinel_docker_supplier_secret_32_chars

# Mail queue:
# - keep false for local Docker without SMTP;
# - set true only after MAIL_* is configured.
DOCKER_MAIL_QUEUE_ENABLED=false
DOCKER_MAIL_HOST=
DOCKER_MAIL_PORT=587
DOCKER_MAIL_SECURE=false
DOCKER_MAIL_USER=
DOCKER_MAIL_PASS=
DOCKER_MAIL_FROM=

# Optional AI providers.
DOCKER_GEMINI_API_KEY=
DOCKER_GROQ_API_KEY=
