MONGODB_URI=mongodb://localhost:27017/pfe_sentinel
PORT=5000

JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=1d
RESET_JWT_EXPIRES_IN=15m
RESET_CODE_TTL_MINUTES=10
RESET_DEV_OTP_ENABLED=true
BCRYPT_SALT_ROUNDS=12
PII_HASH_SECRET=replace_with_long_random_secret

FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

MAIL_QUEUE_ENABLED=true
MAIL_QUEUE_NAME=mail_notifications
MAIL_QUEUE_ATTEMPTS=5
MAIL_QUEUE_BACKOFF_MS=10000
REDIS_URL=redis://localhost:6379

APP_BASE_URL=http://localhost:3000
APP_VERSION=1.0.0

JSON_BODY_LIMIT=2mb
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AI_MAX=60
RATE_LIMIT_CHAT_MAX=180
IDEMPOTENCY_TTL_SECONDS=600

UPLOAD_MAX_MB=10

# Session utilisateur (inactivité)
# Par défaut: 2h. Exemple: 30 min => 1800000
SESSION_INACTIVITY_MS=7200000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=30000

# Twilio (optional) for SMS / WhatsApp OTP
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=

INTERNAL_BOND_QR_SECRET=replace_with_long_random_secret
QR_TOKEN_SECRET=

AI_PYTHON_BIN=python
AI_CACHE_TTL_MS=60000
AI_CACHE_MAX_ITEMS=250
AI_AUTO_TRAIN_ON_BOOT=true
AI_AUTO_TRAINING_ENABLED=true
AI_AUTO_TRAINING_EVERY_MINUTES=360
AI_MIN_TRAINING_INTERVAL_MINUTES=360
AI_MAX_VERSIONS_KEPT=20
AI_AUTO_TRAIN_LOOKBACK_DAYS=240

# Diagnostics (à laisser false en prod)
# Permet de retourner des détails techniques avec ?debug=1 sur certains endpoints IA.
EXPOSE_DIAGNOSTICS=false

TEST_DEMANDEUR_EMAIL=demandeur@example.local
TEST_DEMANDEUR_PASSWORD=ChangeMe_Demandeur_123
TEST_ADMIN_EMAIL=admin@example.local
TEST_ADMIN_PASSWORD=ChangeMe_Admin_123
TEST_MAGASINIER_EMAIL=magasinier@example.local
TEST_MAGASINIER_PASSWORD=ChangeMe_Magasinier_123
TEST_RESPONSABLE_EMAIL=responsable@example.local
TEST_RESPONSABLE_PASSWORD=ChangeMe_Responsable_123
